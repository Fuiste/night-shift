    "      ids.runHistory.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Run History</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Durable journal snapshots for this repo.</span></div>',",
    "        runs.length ? '<div class=' + \"'\" + 'run-list' + \"'\" + '>' + runs.map((run) => {",
    "          const badges = [];",
