import gleam/string

pub fn index_html() -> String {
  [
    "<!doctype html>",
    "<html lang='en'>",
    "<head>",
    "  <meta charset='utf-8'>",
    "  <meta name='viewport' content='width=device-width, initial-scale=1'>",
    "  <title>Night Shift Dash</title>",
    "  <style>",
    "    :root {",
    "      color-scheme: light;",
    "      --ink: #17201f;",
    "      --muted: #5f6f6a;",
    "      --panel: rgba(252, 249, 242, 0.92);",
    "      --panel-strong: #fffdf8;",
    "      --line: rgba(39, 58, 50, 0.14);",
    "      --accent: #0f766e;",
    "      --accent-soft: rgba(15, 118, 110, 0.14);",
    "      --warning: #a16207;",
    "      --danger: #b42318;",
    "      --shadow: 0 16px 40px rgba(20, 30, 27, 0.12);",
    "      font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', serif;",
    "    }",
    "    * { box-sizing: border-box; }",
    "    body {",
    "      margin: 0;",
    "      min-height: 100vh;",
    "      color: var(--ink);",
    "      background:",
    "        radial-gradient(circle at top left, rgba(15, 118, 110, 0.18), transparent 34%),",
    "        radial-gradient(circle at top right, rgba(180, 35, 24, 0.12), transparent 28%),",
    "        linear-gradient(180deg, #f5efe3 0%, #ece6d8 100%);",
    "    }",
    "    a { color: #125f70; }",
    "    button, input, select, textarea { font: inherit; }",
    "    button {",
    "      border: 1px solid transparent;",
    "      border-radius: 999px;",
    "      background: var(--ink);",
    "      color: #fffdf8;",
    "      padding: 0.68rem 1rem;",
    "      cursor: pointer;",
    "    }",
    "    button.secondary { background: #f2ede3; color: var(--ink); border-color: var(--line); }",
    "    button.ghost { background: transparent; color: var(--ink); border-color: var(--line); }",
    "    button:disabled { opacity: 0.45; cursor: not-allowed; }",
    "    input, select, textarea {",
    "      width: 100%;",
    "      border: 1px solid rgba(27, 38, 35, 0.18);",
    "      border-radius: 14px;",
    "      padding: 0.75rem 0.85rem;",
    "      background: rgba(255, 252, 247, 0.96);",
    "      color: var(--ink);",
    "    }",
    "    textarea { min-height: 7rem; resize: vertical; }",
    "    code, pre { font-family: 'SFMono-Regular', 'Menlo', monospace; }",
    "    pre { white-space: pre-wrap; word-break: break-word; }",
    "    .shell {",
    "      max-width: 1520px;",
    "      margin: 0 auto;",
    "      padding: 24px 20px 32px;",
    "      display: grid;",
    "      gap: 18px;",
    "    }",
    "    .hero, .panel {",
    "      background: var(--panel);",
    "      border: 1px solid var(--line);",
    "      border-radius: 24px;",
    "      box-shadow: var(--shadow);",
    "      backdrop-filter: blur(14px);",
    "    }",
    "    .hero { padding: 24px; display: grid; gap: 16px; }",
    "    .hero-top { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; align-items: start; }",
    "    .title { font-size: clamp(2rem, 4vw, 3.6rem); margin: 0; line-height: 0.95; letter-spacing: -0.04em; }",
    "    .lede { margin: 0; max-width: 60rem; color: var(--muted); font-size: 1.02rem; }",
    "    .badge-row, .meta-row, .button-row { display: flex; flex-wrap: wrap; gap: 0.55rem; }",
    "    .badge {",
    "      display: inline-flex;",
    "      align-items: center;",
    "      gap: 0.4rem;",
    "      padding: 0.42rem 0.7rem;",
    "      border-radius: 999px;",
    "      background: rgba(20, 30, 27, 0.08);",
    "      color: var(--ink);",
    "      font-size: 0.82rem;",
    "      letter-spacing: 0.02em;",
    "      text-transform: uppercase;",
    "    }",
    "    .badge.good { background: rgba(15, 118, 110, 0.12); color: #0f5e58; }",
    "    .badge.warn { background: rgba(161, 98, 7, 0.14); color: #8b5a00; }",
    "    .badge.danger { background: rgba(180, 35, 24, 0.14); color: var(--danger); }",
    "    .layout { display: grid; grid-template-columns: minmax(300px, 360px) minmax(0, 1fr); gap: 18px; align-items: start; }",
    "    .sidebar, .workspace { display: grid; gap: 18px; }",
    "    .panel { padding: 18px; }",
    "    .panel h2, .panel h3, .panel h4, .hero h2 { margin: 0 0 0.6rem 0; }",
    "    .panel p { margin-top: 0; }",
    "    .muted { color: var(--muted); }",
    "    .panel-grid { display: grid; gap: 18px; grid-template-columns: repeat(2, minmax(0, 1fr)); }",
    "    .run-list, .task-list, .timeline-list, .artifact-list, .decision-list { display: grid; gap: 0.7rem; }",
    "    .run-card, .task-row, .timeline-card, .artifact-card, .decision-card, .dag-node, .summary-card {",
    "      border: 1px solid var(--line);",
    "      border-radius: 18px;",
    "      padding: 0.9rem;",
    "      background: var(--panel-strong);",
    "    }",
    "    .run-card.active, .task-row.active, .dag-node.active { border-color: rgba(15, 118, 110, 0.55); box-shadow: inset 0 0 0 1px rgba(15, 118, 110, 0.24); }",
    "    .run-card button, .task-row button, .dag-node button { width: 100%; text-align: left; background: transparent; color: inherit; border: none; padding: 0; }",
    "    .run-card button:hover, .task-row button:hover, .dag-node button:hover { opacity: 0.88; }",
    "    .dag-shell { display: grid; gap: 1rem; }",
    "    .dag-columns { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); align-items: start; }",
    "    .dag-column { display: grid; gap: 0.75rem; }",
    "    .dag-column h4 { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }",
    "    .node-state { font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); }",
    "    .node-title { font-size: 1.05rem; margin: 0.25rem 0 0; }",
    "    .node-meta { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.7rem; }",
    "    .pill {",
    "      padding: 0.26rem 0.55rem;",
    "      border-radius: 999px;",
    "      background: rgba(20, 30, 27, 0.07);",
    "      font-size: 0.78rem;",
    "    }",
    "    .columns-2 { display: grid; gap: 18px; grid-template-columns: minmax(260px, 360px) minmax(0, 1fr); }",
    "    .detail-grid { display: grid; gap: 0.9rem; }",
    "    .kv { display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 0.45rem 0.7rem; }",
    "    .kv dt { color: var(--muted); }",
    "    .kv dd { margin: 0; }",
    "    .stack { display: grid; gap: 0.65rem; }",
    "    .split-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; }",
    "    .notice { border-radius: 16px; padding: 0.85rem 0.95rem; border: 1px solid var(--line); background: rgba(20, 30, 27, 0.05); }",
    "    .notice.error { border-color: rgba(180, 35, 24, 0.22); background: rgba(180, 35, 24, 0.08); }",
    "    .notice.success { border-color: rgba(15, 118, 110, 0.22); background: rgba(15, 118, 110, 0.08); }",
    "    .empty { padding: 1rem; border: 1px dashed rgba(23, 32, 31, 0.22); border-radius: 18px; color: var(--muted); }",
    "    .mini { font-size: 0.86rem; color: var(--muted); }",
    "    .mono { font-family: 'SFMono-Regular', 'Menlo', monospace; }",
    "    .form-grid { display: grid; gap: 0.75rem; }",
    "    .form-grid.compact { grid-template-columns: repeat(2, minmax(0, 1fr)); }",
    "    .link-list { display: grid; gap: 0.4rem; }",
    "    .section-head { display: flex; justify-content: space-between; gap: 1rem; align-items: center; flex-wrap: wrap; }",
    "    @media (max-width: 1180px) {",
    "      .layout, .columns-2, .panel-grid { grid-template-columns: minmax(0, 1fr); }",
    "      .sidebar { order: 2; }",
    "    }",
    "    @media (max-width: 700px) {",
    "      .shell { padding: 16px 12px 24px; }",
    "      .hero, .panel { padding: 16px; border-radius: 20px; }",
    "      .form-grid.compact, .kv { grid-template-columns: minmax(0, 1fr); }",
    "      .title { font-size: 2.2rem; }",
    "    }",
    "  </style>",
    "</head>",
    "<body>",
    "  <div class='shell'>",
    "    <section class='hero'>",
    "      <div class='hero-top'>",
    "        <div>",
    "          <p class='badge-row' id='hero-badges'></p>",
    "          <h1 class='title'>Night Shift Dash</h1>",
    "          <p class='lede'>A localhost-only front door for bootstrap, planning, execution, recovery, and audit. The browser consumes the same durable journal and repo-state artifacts as the CLI, which is a mildly radical way to avoid inventing yet another control plane.</p>",
    "        </div>",
    "        <div class='summary-card' id='hero-summary'></div>",
    "      </div>",
    "      <div id='hero-notice'></div>",
    "    </section>",
    "    <div class='layout'>",
    "      <aside class='sidebar'>",
    "        <section class='panel' id='command-center'></section>",
    "        <section class='panel' id='run-history'></section>",
    "      </aside>",
    "      <main class='workspace'>",
    "        <section class='panel' id='dag-panel'></section>",
    "        <div class='columns-2'>",
    "          <section class='panel' id='task-list-panel'></section>",
    "          <section class='panel' id='task-detail-panel'></section>",
    "        </div>",
    "        <div class='panel-grid'>",
    "          <section class='panel' id='timeline-panel'></section>",
    "          <section class='panel' id='audit-panel'></section>",
    "        </div>",
    "      </main>",
    "    </div>",
    "  </div>",
    "  <script>",
    "    const state = {",
    "      bootstrap: null,",
    "      selectedRunId: '',",
    "      selectedTaskId: '',",
    "      stream: null,",
    "      streamKey: '',",
    "      liveStatus: 'connecting',",
    "      notice: '',",
    "      noticeKind: 'neutral',",
    "      providerModels: {},",
    "    };",
    "",
    "    const ids = {",
    "      heroBadges: document.getElementById('hero-badges'),",
    "      heroSummary: document.getElementById('hero-summary'),",
    "      heroNotice: document.getElementById('hero-notice'),",
    "      commandCenter: document.getElementById('command-center'),",
    "      runHistory: document.getElementById('run-history'),",
    "      dagPanel: document.getElementById('dag-panel'),",
    "      taskList: document.getElementById('task-list-panel'),",
    "      taskDetail: document.getElementById('task-detail-panel'),",
    "      timeline: document.getElementById('timeline-panel'),",
    "      audit: document.getElementById('audit-panel'),",
    "    };",
    "",
    "    function escapeHtml(value) {",
    "      return String(value ?? '')",
    "        .replaceAll('&', '&amp;')",
    "        .replaceAll('<', '&lt;')",
    "        .replaceAll('>', '&gt;')",
    "        .replaceAll('\"', '&quot;')",
    "        .replaceAll(\"'\", '&#39;');",
    "    }",
    "",
    "    function asArray(value) {",
    "      return Array.isArray(value) ? value : [];",
    "    }",
    "",
    "    function selectedRun() {",
    "      return state.bootstrap && state.bootstrap.selected_run ? state.bootstrap.selected_run : null;",
    "    }",
    "",
    "    function tasks() {",
    "      const run = selectedRun();",
    "      return run ? asArray(run.tasks) : [];",
    "    }",
    "",
    "    function selectedTask() {",
    "      const runTasks = tasks();",
    "      return runTasks.find((task) => task.id === state.selectedTaskId) || runTasks[0] || null;",
    "    }",
    "",
    "    function runQuery(runId) {",
    "      return runId ? '?run_id=' + encodeURIComponent(runId) : '';",
    "    }",
    "",
    "    async function requestJson(path, options) {",
    "      const response = await fetch(path, Object.assign({ cache: 'no-store' }, options || {}));",
    "      const text = await response.text();",
    "      let payload = {};",
    "      if (text) {",
    "        payload = JSON.parse(text);",
    "      }",
    "      if (!response.ok) {",
    "        const error = new Error(payload.message || (response.status + ' ' + response.statusText));",
    "        error.payload = payload;",
    "        throw error;",
    "      }",
    "      return payload;",
    "    }",
    "",
    "    function setNotice(message, kind) {",
    "      state.notice = message || '';",
    "      state.noticeKind = kind || 'neutral';",
    "      renderHero();",
    "    }",
    "",
    "    function formatList(items, emptyLabel) {",
    "      const values = asArray(items);",
    "      if (!values.length) {",
    "        return '<div class=' + \"'\" + 'empty' + \"'\" + '>' + escapeHtml(emptyLabel || 'No entries yet.') + '</div>';",
    "      }",
    "      return '<div class=' + \"'\" + 'stack' + \"'\" + '>' + values.map((item) => '<div class=' + \"'\" + 'artifact-card' + \"'\" + '>' + escapeHtml(item) + '</div>').join('') + '</div>';",
    "    }",
    "",
    "    function artifactLinks(items) {",
    "      const values = asArray(items);",
    "      if (!values.length) {",
    "        return '<div class=' + \"'\" + 'empty' + \"'\" + '>No artifact paths recorded.</div>';",
    "      }",
    "      return '<div class=' + \"'\" + 'artifact-list' + \"'\" + '>' + values.map((item) => {",
    "        return '<div class=' + \"'\" + 'artifact-card' + \"'\" + '><a href=' + \"'\" + escapeHtml(item.route) + \"'\" + ' target=' + \"'\" + '_blank' + \"'\" + ' rel=' + \"'\" + 'noreferrer' + \"'\" + '>' + escapeHtml(item.path) + '</a></div>';",
    "      }).join('') + '</div>';",
    "    }",
    "",
    "    function statusTone(status) {",
    "      switch (status) {",
    "        case 'completed': return 'good';",
    "        case 'blocked':",
    "        case 'manual_attention': return 'warn';",
    "        case 'failed': return 'danger';",
    "        default: return '';",
    "      }",
    "    }",
    "",
    "    function ensureSelectedTask() {",
    "      const runTasks = tasks();",
    "      if (!runTasks.length) {",
    "        state.selectedTaskId = '';",
    "        return;",
    "      }",
    "      if (!runTasks.some((task) => task.id === state.selectedTaskId)) {",
    "        state.selectedTaskId = runTasks[0].id;",
    "      }",
    "    }",
    "",
    "    function applyBootstrap(payload) {",
    "      state.bootstrap = payload;",
    "      state.selectedRunId = payload && payload.runs ? (payload.runs.selected_run_id || '') : '';",
    "      ensureSelectedTask();",
    "      render();",
    "      ensureStream();",
    "      const provider = readInitProvider();",
    "      if (provider) {",
    "        void loadProviderModels(provider);",
    "      }",
    "    }",
    "",
    "    function buildDagColumns(runTasks) {",
    "      const map = new Map(runTasks.map((task) => [task.id, task]));",
    "      const depths = new Map();",
    "      function depthFor(task) {",
    "        if (depths.has(task.id)) return depths.get(task.id);",
    "        const dependencies = asArray(task.dependencies).map((id) => map.get(id)).filter(Boolean);",
    "        const value = dependencies.length ? Math.max(...dependencies.map(depthFor)) + 1 : 0;",
    "        depths.set(task.id, value);",
    "        return value;",
    "      }",
    "      runTasks.forEach(depthFor);",
    "      const groups = [];",
    "      runTasks.forEach((task) => {",
    "        const depth = depths.get(task.id) || 0;",
    "        if (!groups[depth]) groups[depth] = [];",
    "        groups[depth].push(task);",
    "      });",
    "      return groups.filter(Boolean);",
    "    }",
    "",
    "    function renderHero() {",
    "      const bootstrap = state.bootstrap;",
    "      const run = selectedRun();",
    "      const badges = [];",
    "      badges.push('<span class=' + \"'\" + 'badge ' + (bootstrap && bootstrap.initialized ? 'good' : 'warn') + \"'\" + '>' + escapeHtml(bootstrap && bootstrap.initialized ? 'initialized' : 'awaiting init') + '</span>');",
    "      badges.push('<span class=' + \"'\" + 'badge ' + statusTone(run ? run.status : '') + \"'\" + '>' + escapeHtml(run ? run.status : 'no active run') + '</span>');",
    "      badges.push('<span class=' + \"'\" + 'badge ' + (state.liveStatus === 'live' ? 'good' : state.liveStatus === 'disconnected' ? 'warn' : '') + \"'\" + '>sse ' + escapeHtml(state.liveStatus) + '</span>');",
    "      ids.heroBadges.innerHTML = badges.join('');",
    "      ids.heroSummary.innerHTML = bootstrap ? [",
    "        '<div class=' + \"'\" + 'stack' + \"'\" + '>',",
    "        '<div><strong>Repo</strong><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(bootstrap.repo_root) + '</div></div>',",
    "        '<div><strong>Selected run</strong><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(state.selectedRunId || 'none') + '</div></div>',",
    "        '<div><strong>Config</strong><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(bootstrap.config_path) + '</div></div>',",
    "        '</div>'",
    "      ].join('') : '<div class=' + \"'\" + 'mini' + \"'\" + '>Loading repo bootstrap...</div>';",
    "      ids.heroNotice.innerHTML = state.notice ? '<div class=' + \"'\" + 'notice ' + (state.noticeKind === 'error' ? 'error' : state.noticeKind === 'success' ? 'success' : '') + \"'\" + '>' + escapeHtml(state.notice) + '</div>' : '';",
    "    }",
    "",
    "    function renderCommandCenter() {",
    "      const bootstrap = state.bootstrap;",
    "      const run = selectedRun();",
    "      if (!bootstrap) {",
    "        ids.commandCenter.innerHTML = '<h2>Command Center</h2><div class=' + \"'\" + 'empty' + \"'\" + '>Loading command surface...</div>';",
    "        return;",
    "      }",
    "      const initModels = asArray(state.providerModels[readInitProvider()] || []);",
    "      const initModelOptions = initModels.map((model) => '<option value=' + \"'\" + escapeHtml(model.id) + \"'\" + '>' + escapeHtml(model.label) + (model.is_default ? ' (default)' : '') + '</option>').join('');",
    "      const actionButtons = run ? [",
    "        '<button type=' + \"'\" + 'button' + \"'\" + ' data-command=' + \"'\" + 'start' + \"'\" + '>' + 'Start selected run' + '</button>',",
    "        '<button type=' + \"'\" + 'button' + \"'\" + ' class=' + \"'\" + 'secondary' + \"'\" + ' data-command=' + \"'\" + 'resume' + \"'\" + '>' + 'Resume selected run' + '</button>'",
    "      ].join('') : '<button type=' + \"'\" + 'button' + \"'\" + ' disabled>No run selected</button>';",
    "      const decisionCards = run && asArray(run.decision_requests).length ? '<form id=' + \"'\" + 'resolve-form' + \"'\" + ' class=' + \"'\" + 'form-grid' + \"'\" + '>' + asArray(run.decision_requests).map((entry) => {",
    "        const request = entry.request || {};",
    "        const options = asArray(request.options).map((option) => '<option value=' + \"'\" + escapeHtml(option.label) + \"'\" + '>' + escapeHtml(option.label + ' - ' + option.description) + '</option>').join('');",
    "        const recommended = request.recommended_option ? '<div class=' + \"'\" + 'mini' + \"'\" + '>Recommended: ' + escapeHtml(request.recommended_option) + '</div>' : '';",
    "        const input = options ? '<select name=' + \"'\" + escapeHtml(request.key) + \"'\" + '><option value=' + \"'\" + '' + \"'\" + '>Select an answer</option>' + options + '</select>' : '<textarea name=' + \"'\" + escapeHtml(request.key) + \"'\" + ' placeholder=' + \"'\" + 'Write the decision answer' + \"'\" + '></textarea>';",
    "        return '<div class=' + \"'\" + 'decision-card' + \"'\" + '><strong>' + escapeHtml(entry.task_title || entry.task_id) + '</strong><div>' + escapeHtml(request.question || '') + '</div><div class=' + \"'\" + 'mini' + \"'\" + '>' + escapeHtml(request.rationale || '') + '</div>' + recommended + input + '</div>';",
    "      }).join('') + '<button type=' + \"'\" + 'submit' + \"'\" + '>Resolve decisions</button></form>' : '<div class=' + \"'\" + 'empty' + \"'\" + '>No unresolved decisions for the selected run.</div>';",
    "      ids.commandCenter.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Command Center</h2><span class=' + \"'\" + 'mini' + \"'\" + '>POST-backed commands mutate the same journal as the CLI.</span></div>',",
    "        bootstrap.initialized ? '' : [",
    "          '<div class=' + \"'\" + 'stack' + \"'\" + '>',",
    "          '<p class=' + \"'\" + 'muted' + \"'\" + '>Initialize in place and keep the Dash session alive.</p>',",
    "          '<form id=' + \"'\" + 'init-form' + \"'\" + ' class=' + \"'\" + 'form-grid' + \"'\" + '>',",
    "          '<label>Provider<select id=' + \"'\" + 'init-provider' + \"'\" + ' name=' + \"'\" + 'provider' + \"'\" + '><option value=' + \"'\" + 'codex' + \"'\" + '>codex</option><option value=' + \"'\" + 'cursor' + \"'\" + '>cursor</option></select></label>',",
    "          '<label>Model<select id=' + \"'\" + 'init-model' + \"'\" + ' name=' + \"'\" + 'model' + \"'\" + '><option value=' + \"'\" + '' + \"'\" + '>Choose a local model</option>' + initModelOptions + '</select></label>',",
    "          '<label>Reasoning<select name=' + \"'\" + 'reasoning' + \"'\" + '><option value=' + \"'\" + '' + \"'\" + '>default</option><option value=' + \"'\" + 'low' + \"'\" + '>low</option><option value=' + \"'\" + 'medium' + \"'\" + '>medium</option><option value=' + \"'\" + 'high' + \"'\" + '>high</option><option value=' + \"'\" + 'xhigh' + \"'\" + '>xhigh</option></select></label>',",
    "          '<label><input type=' + \"'\" + 'checkbox' + \"'\" + ' name=' + \"'\" + 'generate_setup' + \"'\" + '> Generate worktree setup when missing</label>',",
    "          '<button type=' + \"'\" + 'submit' + \"'\" + '>Initialize repository</button>',",
    "          '</form>',",
    "          '</div>'",
    "        ].join('') : '',",
    "        bootstrap.initialized ? [",
    "          '<form id=' + \"'\" + 'plan-form' + \"'\" + ' class=' + \"'\" + 'form-grid' + \"'\" + '>',",
    "          '<h3>Plan from notes</h3>',",
    "          '<textarea name=' + \"'\" + 'notes' + \"'\" + ' placeholder=' + \"'\" + 'Paste notes or a file path. The planner will decide whether this feels monoidal enough to become a run.' + \"'\" + '></textarea>',",
    "          '<div class=' + \"'\" + 'form-grid compact' + \"'\" + '><label>Doc path<input name=' + \"'\" + 'doc_path' + \"'\" + ' placeholder=' + \"'\" + '.night-shift/execution-brief.md' + \"'\" + '></label><label>Profile override<input name=' + \"'\" + 'profile' + \"'\" + ' placeholder=' + \"'\" + 'optional profile name' + \"'\" + '></label></div>',",
    "          '<button type=' + \"'\" + 'submit' + \"'\" + '>Plan run</button>',",
    "          '</form>',",
    "          '<form id=' + \"'\" + 'review-plan-form' + \"'\" + ' class=' + \"'\" + 'form-grid' + \"'\" + '>',",
    "          '<h3>Plan from reviews</h3>',",
    "          '<textarea name=' + \"'\" + 'notes' + \"'\" + ' placeholder=' + \"'\" + 'Optional notes blended into the review-driven replanning pass.' + \"'\" + '></textarea>',",
    "          '<div class=' + \"'\" + 'form-grid compact' + \"'\" + '><label>Doc path<input name=' + \"'\" + 'doc_path' + \"'\" + ' placeholder=' + \"'\" + 'optional alternate brief path' + \"'\" + '></label><label>Profile override<input name=' + \"'\" + 'profile' + \"'\" + ' placeholder=' + \"'\" + 'optional profile name' + \"'\" + '></label></div>',",
    "          '<button type=' + \"'\" + 'submit' + \"'\" + ' class=' + \"'\" + 'secondary' + \"'\" + '>Plan from reviews</button>',",
    "          '</form>',",
    "          '<div class=' + \"'\" + 'stack' + \"'\" + '><h3>Execution</h3><div class=' + \"'\" + 'split-actions' + \"'\" + '>' + actionButtons + '</div></div>',",
    "          '<div class=' + \"'\" + 'stack' + \"'\" + '><h3>Decision resolution</h3>' + decisionCards + '</div>'",
    "        ].join('') : '',",
    "      ].join('');",
    "    }",
    "",
    "    function renderRunHistory() {",
    "      const bootstrap = state.bootstrap;",
