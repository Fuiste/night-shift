    "        }).join('') + '</div>' : '<div class=' + \"'\" + 'empty' + \"'\" + '>No runs yet. Plan from notes or reviews to create one.</div>'",
    "      ].join('');",
    "    }",
    "",
    "    function renderDag() {",
    "      const run = selectedRun();",
    "      if (!run) {",
    "        ids.dagPanel.innerHTML = '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Task DAG</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Graph view appears once a run exists.</span></div><div class=' + \"'\" + 'empty' + \"'\" + '>Plan a run to populate the DAG.</div>';",
    "        return;",
    "      }",
    "      const columns = buildDagColumns(tasks());",
    "      ids.dagPanel.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Task DAG</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Graph and list/detail stay synchronized on the selected task.</span></div>',",
    "        '<div class=' + \"'\" + 'badge-row' + \"'\" + '>',",
    "        '<span class=' + \"'\" + 'badge' + \"'\" + '>tasks ' + escapeHtml(run.task_dag.task_count) + '</span>',",
    "        '<span class=' + \"'\" + 'badge good' + \"'\" + '>ready ' + escapeHtml(asArray(run.task_dag.ready_task_ids).length) + '</span>',",
    "        '<span class=' + \"'\" + 'badge' + \"'\" + '>running ' + escapeHtml(asArray(run.task_dag.running_task_ids).length) + '</span>',",
    "        '<span class=' + \"'\" + 'badge warn' + \"'\" + '>blocked ' + escapeHtml(asArray(run.task_dag.blocked_task_ids).length) + '</span>',",
    "        '</div>',",
    "        '<div class=' + \"'\" + 'dag-shell' + \"'\" + '><div class=' + \"'\" + 'dag-columns' + \"'\" + '>' + columns.map((column, index) => {",
    "          return '<div class=' + \"'\" + 'dag-column' + \"'\" + '><h4>Stage ' + escapeHtml(index + 1) + '</h4>' + column.map((task) => {",
    "            return '<div class=' + \"'\" + 'dag-node ' + (state.selectedTaskId === task.id ? 'active' : '') + \"'\" + '><button type=' + \"'\" + 'button' + \"'\" + ' data-task-id=' + \"'\" + escapeHtml(task.id) + \"'\" + '><div class=' + \"'\" + 'node-state' + \"'\" + '>' + escapeHtml(task.state) + '</div><p class=' + \"'\" + 'node-title' + \"'\" + '>' + escapeHtml(task.title) + '</p><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(task.id) + '</div><div class=' + \"'\" + 'node-meta' + \"'\" + '><span class=' + \"'\" + 'pill' + \"'\" + '>' + escapeHtml(task.task_kind) + '</span><span class=' + \"'\" + 'pill' + \"'\" + '>' + escapeHtml(task.execution_mode) + '</span><span class=' + \"'\" + 'pill' + \"'\" + '>deps ' + escapeHtml(asArray(task.dependencies).length) + '</span></div></button></div>';",
    "          }).join('') + '</div>';",
    "        }).join('') + '</div></div>'",
    "      ].join('');",
    "    }",
    "",
    "    function renderTaskList() {",
    "      const run = selectedRun();",
    "      if (!run) {",
    "        ids.taskList.innerHTML = '<h2>Tasks</h2><div class=' + \"'\" + 'empty' + \"'\" + '>No task list yet.</div>';",
    "        return;",
    "      }",
    "      ids.taskList.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Tasks</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Pending, running, blocked, and delivered work.</span></div>',",
    "        '<div class=' + \"'\" + 'task-list' + \"'\" + '>' + tasks().map((task) => {",
    "          return '<div class=' + \"'\" + 'task-row ' + (state.selectedTaskId === task.id ? 'active' : '') + \"'\" + '><button type=' + \"'\" + 'button' + \"'\" + ' data-task-id=' + \"'\" + escapeHtml(task.id) + \"'\" + '><div class=' + \"'\" + 'section-head' + \"'\" + '><strong>' + escapeHtml(task.title) + '</strong><span class=' + \"'\" + 'badge ' + statusTone(task.state) + \"'\" + '>' + escapeHtml(task.state) + '</span></div><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(task.id) + '</div><div class=' + \"'\" + 'badge-row' + \"'\" + '><span class=' + \"'\" + 'badge' + \"'\" + '>' + escapeHtml(task.task_kind) + '</span><span class=' + \"'\" + 'badge' + \"'\" + '>' + escapeHtml(task.execution_mode) + '</span></div></button></div>';",
    "        }).join('') + '</div>'",
    "      ].join('');",
    "    }",
    "",
    "    function renderTaskDetail() {",
    "      const task = selectedTask();",
    "      if (!task) {",
    "        ids.taskDetail.innerHTML = '<h2>Task Detail</h2><div class=' + \"'\" + 'empty' + \"'\" + '>Select a task to inspect metadata, lineage, runtime context, and artifacts.</div>';",
    "        return;",
    "      }",
    "      const runtime = task.runtime_context || {};",
    "      const delivered = task.delivered_pr || null;",
    "      const artifactSections = task.artifacts || {};",
    "      ids.taskDetail.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Task Detail</h2><span class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(task.id) + '</span></div>',",
    "        '<div class=' + \"'\" + 'detail-grid' + \"'\" + '>',",
    "        '<div><h3>' + escapeHtml(task.title) + '</h3><p>' + escapeHtml(task.description) + '</p></div>',",
    "        '<dl class=' + \"'\" + 'kv' + \"'\" + '><dt>State</dt><dd>' + escapeHtml(task.state) + '</dd><dt>Kind</dt><dd>' + escapeHtml(task.task_kind) + '</dd><dt>Mode</dt><dd>' + escapeHtml(task.execution_mode) + '</dd><dt>Dependencies</dt><dd>' + escapeHtml(asArray(task.dependencies).join(', ') || 'none') + '</dd><dt>Branch</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(task.branch_name || 'not assigned') + '</dd><dt>Worktree</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(task.worktree_path || 'not prepared') + '</dd></dl>',",
    "        '<div><h3>Acceptance</h3>' + formatList(task.acceptance, 'No acceptance criteria recorded.') + '</div>',",
    "        '<div><h3>Demo Plan</h3>' + formatList(task.demo_plan, 'No demo plan recorded.') + '</div>',",
    "        '<div><h3>Decision Requests</h3>' + formatList(asArray(task.unresolved_decision_requests).map((request) => request.question), 'No unresolved decisions for this task.') + '</div>',",
    "        '<div><h3>Runtime Context</h3><dl class=' + \"'\" + 'kv' + \"'\" + '><dt>Worktree ID</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(runtime.worktree_id || 'n/a') + '</dd><dt>Compose Project</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(runtime.compose_project || 'n/a') + '</dd><dt>Port Base</dt><dd>' + escapeHtml(runtime.port_base || 'n/a') + '</dd><dt>Manifest</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(runtime.manifest_path || 'n/a') + '</dd><dt>Handoff</dt><dd class=' + \"'\" + 'mono' + \"'\" + '>' + escapeHtml(runtime.handoff_path || 'n/a') + '</dd></dl></div>',",
    "        '<div><h3>Delivery</h3>' + (delivered ? '<div class=' + \"'\" + 'stack' + \"'\" + '><div>PR #' + escapeHtml(delivered.number) + '</div>' + (delivered.url ? '<a href=' + \"'\" + escapeHtml(delivered.url) + \"'\" + ' target=' + \"'\" + '_blank' + \"'\" + ' rel=' + \"'\" + 'noreferrer' + \"'\" + '>Open delivered PR</a>' : '') + '</div>' : '<div class=' + \"'\" + 'empty' + \"'\" + '>No delivered PR yet.</div>') + '</div>',",
    "        '<div><h3>Artifacts</h3>' + artifactLinks([].concat(asArray(artifactSections.prompts), asArray(artifactSections.logs), asArray(artifactSections.raw_payloads), asArray(artifactSections.sanitized_payloads), artifactSections.runtime_manifest ? [artifactSections.runtime_manifest] : [], artifactSections.runtime_handoff ? [artifactSections.runtime_handoff] : [], artifactSections.runtime_env ? [artifactSections.runtime_env] : [])) + '</div>',",
    "        '</div>'",
    "      ].join('');",
    "    }",
    "",
    "    function renderTimeline() {",
    "      const run = selectedRun();",
    "      if (!run) {",
    "        ids.timeline.innerHTML = '<h2>Timeline</h2><div class=' + \"'\" + 'empty' + \"'\" + '>Timeline data appears once a run exists.</div>';",
    "        return;",
    "      }",
    "      const selectedTaskValue = selectedTask();",
    "      const selectedTaskId = selectedTaskValue ? selectedTaskValue.id : '';",
    "      const items = asArray(run.timeline).filter((event) => !selectedTaskId || !event.task_id || event.task_id === selectedTaskId);",
    "      ids.timeline.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Timeline</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Filtered to the selected task when possible.</span></div>',",
    "        items.length ? '<div class=' + \"'\" + 'timeline-list' + \"'\" + '>' + items.map((event) => {",
    "          return '<div class=' + \"'\" + 'timeline-card' + \"'\" + '><div class=' + \"'\" + 'section-head' + \"'\" + '><strong>' + escapeHtml(event.kind) + '</strong><span class=' + \"'\" + 'mini' + \"'\" + '>' + escapeHtml(event.at) + '</span></div><div>' + escapeHtml(event.message) + '</div>' + (event.task_id ? '<div class=' + \"'\" + 'mini mono' + \"'\" + '>task ' + escapeHtml(event.task_id) + '</div>' : '') + '</div>';",
    "        }).join('') + '</div>' : '<div class=' + \"'\" + 'empty' + \"'\" + '>No timeline entries yet.</div>'",
    "      ].join('');",
    "    }",
    "",
    "    function renderAudit() {",
    "      const run = selectedRun();",
    "      if (!run) {",
    "        ids.audit.innerHTML = '<h2>Audit</h2><div class=' + \"'\" + 'empty' + \"'\" + '>Audit surfaces appear once a run exists.</div>';",
    "        return;",
    "      }",
    "      const report = run.report || {};",
    "      const provenance = run.provenance || {};",
    "      const repoState = run.repo_state || null;",
    "      const lineage = run.review_lineage || null;",
    "      const delivery = tasks().filter((task) => task.delivered_pr).map((task) => task.id + ' -> PR #' + task.delivered_pr.number);",
    "      ids.audit.innerHTML = [",
    "        '<div class=' + \"'\" + 'section-head' + \"'\" + '><h2>Audit</h2><span class=' + \"'\" + 'mini' + \"'\" + '>Report, provenance, repo-state drift, lineage, and delivery context.</span></div>',",
    "        '<div class=' + \"'\" + 'stack' + \"'\" + '>',",
    "        '<div class=' + \"'\" + 'summary-card' + \"'\" + '><strong>Status summary</strong><div class=' + \"'\" + 'mini' + \"'\" + '>Run ' + escapeHtml(run.status) + ', confidence ' + escapeHtml(run.confidence_posture) + '</div><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(run.run_id) + '</div></div>',",
    "        '<div><h3>Confidence</h3>' + formatList(run.confidence_reasons, 'No confidence notes recorded.') + '</div>',",
    "        '<div><h3>Report</h3><div class=' + \"'\" + 'link-list' + \"'\" + '><a href=' + \"'\" + escapeHtml(report.route || '#') + \"'\" + ' target=' + \"'\" + '_blank' + \"'\" + ' rel=' + \"'\" + 'noreferrer' + \"'\" + '>Open report artifact</a><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(report.path || '') + '</div><pre>' + escapeHtml(report.content || '') + '</pre></div></div>',",
    "        '<div><h3>Provenance</h3><div class=' + \"'\" + 'link-list' + \"'\" + '><a href=' + \"'\" + escapeHtml(provenance.route || '#') + \"'\" + ' target=' + \"'\" + '_blank' + \"'\" + ' rel=' + \"'\" + 'noreferrer' + \"'\" + '>Open provenance artifact</a><div class=' + \"'\" + 'mini mono' + \"'\" + '>' + escapeHtml(provenance.path || '') + '</div></div></div>',",
    "        '<div><h3>Repo state</h3>' + (repoState ? '<dl class=' + \"'\" + 'kv' + \"'\" + '><dt>Snapshot captured</dt><dd>' + escapeHtml(repoState.snapshot_captured_at) + '</dd><dt>Drift</dt><dd>' + escapeHtml(repoState.drift || 'none') + '</dd><dt>Drift details</dt><dd>' + escapeHtml(repoState.drift_details || 'none') + '</dd><dt>Actionable PRs</dt><dd>' + escapeHtml(asArray(repoState.actionable_pull_requests).length) + '</dd><dt>Impacted PRs</dt><dd>' + escapeHtml(asArray(repoState.impacted_pull_requests).length) + '</dd></dl>' : '<div class=' + \"'\" + 'empty' + \"'\" + '>No repo-state snapshot for this run.</div>') + '</div>',",
    "        '<div><h3>Review lineage</h3>' + (lineage ? formatList(asArray(lineage.lineage_entries).map((entry) => entry.task_id + ' replaced ' + asArray(entry.superseded_pr_numbers).join(', ')), 'No replacement lineage recorded.') : '<div class=' + \"'\" + 'empty' + \"'\" + '>No review lineage recorded.</div>') + '</div>',",
    "        '<div><h3>Delivery context</h3>' + formatList(delivery, 'No delivered PR linkage yet.') + '</div>',",
    "        '<div><h3>Planning artifacts</h3>' + artifactLinks([].concat(asArray(run.planning_artifacts), run.planner_prompt ? [run.planner_prompt] : [], run.planner_log ? [run.planner_log] : [])) + '</div>',",
    "        '</div>'",
    "      ].join('');",
    "    }",
    "",
    "    function render() {",
    "      renderHero();",
    "      renderCommandCenter();",
    "      renderRunHistory();",
    "      renderDag();",
    "      renderTaskList();",
    "      renderTaskDetail();",
    "      renderTimeline();",
    "      renderAudit();",
    "    }",
    "",
    "    function ensureStream() {",
    "      const key = '/api/events' + runQuery(state.selectedRunId);",
    "      if (state.streamKey === key && state.stream) return;",
    "      if (state.stream) state.stream.close();",
    "      state.streamKey = key;",
    "      state.liveStatus = 'connecting';",
    "      renderHero();",
    "      const source = new EventSource(key);",
    "      state.stream = source;",
    "      source.onopen = () => {",
    "        state.liveStatus = 'live';",
    "        renderHero();",
    "      };",
    "      const applyEvent = (event) => {",
    "        try {",
    "          applyBootstrap(JSON.parse(event.data));",
    "          state.liveStatus = 'live';",
    "          renderHero();",
    "        } catch (error) {",
    "          setNotice(error.message, 'error');",
    "        }",
    "      };",
    "      source.addEventListener('bootstrap', applyEvent);",
    "      source.addEventListener('state', applyEvent);",
    "      source.addEventListener('error', (event) => {",
    "        if (event.data) {",
    "          try {",
    "            const payload = JSON.parse(event.data);",
    "            setNotice(payload.message || 'Dash event stream reported an error.', 'error');",
    "          } catch (_error) {",
    "            setNotice('Dash event stream reported an error.', 'error');",
    "          }",
    "        }",
    "      });",
    "      source.onerror = () => {",
    "        state.liveStatus = 'disconnected';",
    "        renderHero();",
    "      };",
    "    }",
    "",
    "    async function refreshBootstrap(runId) {",
    "      const payload = await requestJson('/api/bootstrap' + runQuery(runId));",
    "      applyBootstrap(payload);",
    "    }",
    "",
    "    async function executeCommand(command, body) {",
    "      try {",
    "        const payload = await requestJson('/api/commands/' + command, {",
    "          method: 'POST',",
    "          headers: { 'Content-Type': 'application/json; charset=utf-8' },",
    "          body: JSON.stringify(body || {}),",
    "        });",
    "        if (payload.bootstrap) {",
    "          applyBootstrap(payload.bootstrap);",
    "        }",
    "        setNotice(payload.message || ('Executed ' + command + '.'), 'success');",
    "      } catch (error) {",
    "        if (error.payload && error.payload.bootstrap) {",
    "          applyBootstrap(error.payload.bootstrap);",
    "        }",
    "        setNotice(error.message || ('Unable to execute ' + command + '.'), 'error');",
    "      }",
    "    }",
    "",
    "    function readInitProvider() {",
    "      const select = document.getElementById('init-provider');",
    "      return select ? select.value : 'codex';",
    "    }",
    "",
    "    async function loadProviderModels(provider) {",
    "      if (!provider || state.providerModels[provider]) return;",
    "      try {",
    "        const payload = await requestJson('/api/provider-models?provider=' + encodeURIComponent(provider));",
    "        state.providerModels[provider] = payload.models || [];",
    "        renderCommandCenter();",
    "      } catch (error) {",
    "        state.providerModels[provider] = [];",
    "        setNotice(error.message || 'Unable to load provider models.', 'error');",
    "      }",
    "    }",
    "",
    "    document.addEventListener('change', (event) => {",
    "      if (event.target && event.target.id === 'init-provider') {",
    "        void loadProviderModels(event.target.value);",
    "      }",
    "    });",
    "",
    "    document.addEventListener('click', (event) => {",
    "      const runButton = event.target.closest('[data-run-id]');",
    "      if (runButton) {",
    "        void refreshBootstrap(runButton.getAttribute('data-run-id'));",
    "        return;",
    "      }",
    "      const taskButton = event.target.closest('[data-task-id]');",
    "      if (taskButton) {",
    "        state.selectedTaskId = taskButton.getAttribute('data-task-id') || '';",
    "        render();",
    "        return;",
    "      }",
    "      const commandButton = event.target.closest('[data-command]');",
    "      if (commandButton) {",
    "        const command = commandButton.getAttribute('data-command');",
    "        void executeCommand(command, { run_id: state.selectedRunId });",
    "      }",
    "    });",
    "",
    "    document.addEventListener('submit', (event) => {",
    "      const form = event.target;",
    "      if (!(form instanceof HTMLFormElement)) return;",
    "      event.preventDefault();",
    "      const data = new FormData(form);",
    "      if (form.id === 'init-form') {",
    "        void executeCommand('init', {",
    "          provider: String(data.get('provider') || ''),",
    "          model: String(data.get('model') || ''),",
    "          reasoning: String(data.get('reasoning') || ''),",
    "          generate_setup: data.get('generate_setup') === 'on',",
    "        });",
    "      }",
    "      if (form.id === 'plan-form') {",
    "        void executeCommand('plan', {",
    "          notes: String(data.get('notes') || ''),",
    "          doc_path: String(data.get('doc_path') || ''),",
    "          profile: String(data.get('profile') || ''),",
    "        });",
    "      }",
    "      if (form.id === 'review-plan-form') {",
    "        void executeCommand('plan-from-reviews', {",
    "          notes: String(data.get('notes') || ''),",
    "          doc_path: String(data.get('doc_path') || ''),",
    "          profile: String(data.get('profile') || ''),",
    "        });",
    "      }",
    "      if (form.id === 'resolve-form') {",
    "        const run = selectedRun();",
    "        const answers = asArray(run && run.decision_requests).map((entry) => {",
    "          const key = entry.request ? entry.request.key : '';",
    "          return { key, answer: String(data.get(key) || '') };",
    "        }).filter((entry) => entry.key && entry.answer);",
    "        void executeCommand('resolve', { run_id: state.selectedRunId, answers });",
    "      }",
    "    });",
    "",
    "    void refreshBootstrap('');",
    "  </script>",
    "</body>",
    "</html>",
  ]
  |> string.join(with: "\n")
}
